# Variáveis de Ambiente - Exemplo para Configuração

# ===== API CONFIGURATION =====
VITE_API_BASE_URL=http://localhost:3001
VITE_OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ===== FEATURE FLAGS =====
VITE_LLM_MOCK_MODE=true
VITE_ENABLE_VOICE=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# ===== DEPLOYMENT INFO =====
VITE_APP_VERSION=1.0.0-dev
VITE_ENVIRONMENT=development
VITE_BUILD_DATE=auto

# ===== BACKEND CONFIGURATION (Para backend local) =====
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...your-service-key
# SUPABASE_ANON_KEY=eyJ...your-anon-key

# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENAI_API_KEY=sk-your-openai-key

# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT_SECRET=your-super-secret-jwt-key-for-development
# ENCRYPTION_KEY=your-32-char-encryption-key-dev

# RATE_LIMIT_REQUESTS=1000
# RATE_LIMIT_WINDOW=900000

# ===== INSTRUÇÕES =====
# 1. Copie este arquivo para .env.local (desenvolvimento)
# 2. Configure suas chaves reais de API
# 3. Para produção, configure as variáveis no Vercel Dashboard
# 4. Nunca commite arquivos .env com chaves reais!
