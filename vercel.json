{
  "version": 2,
  "builds": [
    {
      "src": "autvisionai-front/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "outputDirectory": "autvisionai-front/dist",
  "installCommand": "cd autvisionai-front && npm install",
  "buildCommand": "cd autvisionai-front && npm run build"
}