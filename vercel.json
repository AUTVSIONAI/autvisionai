{
  "version": 2,
  "buildCommand": "cd autvisionai-front && npm ci && npm run build",
  "outputDirectory": "autvisionai-front/dist",
  "installCommand": "cd autvisionai-front && npm ci",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "env": {
    "VITE_SUPABASE_URL": "@vite_supabase_url",
    "VITE_SUPABASE_ANON_KEY": "@vite_supabase_anon_key",
    "VITE_API_BASE_URL": "@vite_api_base_url",
    "VITE_LLM_MOCK_MODE": "@vite_llm_mock_mode",
    "VITE_ENVIRONMENT": "@vite_environment"
  }
}